CONFIG_NVS_FLASH = y
CONFIG_TCP_CLI = y

CONFIG_SMART_CONNECTION = y
CONFIG_BCAST_FOTA_STA = n
CONFIG_TCP_FOTA = y
CONFIG_IDLE_POWER_SAVE = n

CONFIG_SSD1306 = n
CONFIG_EPAPER = n
ifneq ($(findstring epaper, $(ALIAS)), )
CONFIG_SSD1306 = n
CONFIG_EPAPER = y
endif
ifneq ($(findstring oled, $(ALIAS)), )
CONFIG_SSD1306 = y
CONFIG_EPAPER = n
endif

CONFIG_PING_ON_WIFI_CONNECT = y
CONFIG_LINK_STATUS_PUSH_CLIENT = y

CONFIG_TCP_CLI = y

# LittleFS filesystem
CONFIG_LITTLEFS = y

CONFIG_NANOPB = y

########################################

ifeq ($(CONFIG_SMART_CONNECTION),y)
DEFINE += -DSMART_CONNECTION_ENABLE
endif

ifeq ($(CONFIG_BCAST_FOTA_STA),y)
DEFINE += -DSUPPORT_BCAST_FOTA
endif

ifeq ($(CONFIG_TCP_FOTA),y)
DEFINE += -DSUPPORT_TCP_FOTA
endif

ifeq ($(CONFIG_IDLE_POWER_SAVE),y)
DEFINE += -DIDLE_POWER_SAVE_ENABLE
endif

ifeq ($(CONFIG_PING_ON_WIFI_CONNECT),y)
DEFINE += -DPING_ON_WIFI_CONNECT
endif

ifeq ($(CONFIG_LINK_STATUS_PUSH_CLIENT),y)
DEFINE += -DLINK_STATUS_PUSH_CLIENT
endif

ifeq ($(CONFIG_NANOPB),y)
DEFINE += -DUSE_NANOPB
endif

DEFINE += -DMAX_DEVICES=64
DEFINE += -DMAX_ADDRESSED_DEVICES=16

#DEFINE += -DBCMC_COLLISION_AWARE_ENABLE
#DEFINE += -DLWIP_DHCP_REQUEST_TIMEOUT_SECONDS=32
DEFINE += -DDHCPS_LEASE_TIME_DEF=1200000
#DEFINE += -DBRIDGE_STATIC_IP_BY_RELAY_NUMBER
#DEFINE += -DENABLE_TASK_KEEPALIVE
#DEFINE += -DFC_LFS_FILE_BACKUP

DEFINE += -DCONN_TIMER_TIMEOUT=120
DEFINE += -DCTIMER0_INTERVAL=10
########################################

CONFIG_NRC7394_EVK=y

ifeq ($(CONFIG_LITTLEFS),y)
CONFIG_LFS_TEST=n
endif

ifeq ($(CONFIG_LFS_TEST),y)
DEFINE += -DDISABLE_AUTO_RECOVERY
DEFINE += -DDISABLE_UART_LOOPBACK
endif

ifeq ($(CONFIG_LFS_TEST),y)
DEFINE += -DTEST_LFS_SMARTCONN
endif

